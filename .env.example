# --- Sensor (ESP32 WebSocket) ---
# Disable the WebSocket connection entirely — handy while developing without
# any ESP32 hooked up (silences the recurring "WebSocket failed" console log).
# Default if unset: enabled.
VITE_SENSOR_ENABLED=false

# WebSocket URL the React app connects to for sensor events.
# Point this at your ESP32's IP address (or any device hosting a WS server).
# Default if unset: ws://localhost:81/
VITE_SENSOR_WS_URL=ws://192.168.1.42:81/

# --- Model inference server (model_server.py / best_model.pt) ---
# URL the React app POSTs the captured photo to for classification.
# Run the server with:  python model_server.py
# Default if unset: http://localhost:8000/classify
VITE_MODEL_API_URL=http://localhost:8000/classify
